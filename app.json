{
  "expo": {
    "name": "V Drive",
    "slug": "oneDriveVensarApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/appstore-icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/appstore-icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.vensar.vdrive"
    },
    "android": {
      "icon": "./assets/playstore-icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#FAFAFA"
      },
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.vensar.vdrive"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Use Face ID to securely unlock Vensar Drive and access your company files."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to securely unlock Vensar Drive and access your company files."
        }
      ],
      "expo-web-browser",
      "expo-image",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F3F8FC",
          "image": "./assets/transparent-splash.svg",
          "imageWidth": 1,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0F172A",
            "image": "./assets/transparent-splash.svg"
          }
        }
      ],
      "expo-sharing"
    ]
  }
}
