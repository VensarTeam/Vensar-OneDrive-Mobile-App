{
  "expo": {
    "name": "oneDriveVensarApp",
    "slug": "oneDriveVensarApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/appstore-icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": {
        "light": "./assets/appstore-icon.png",
        "dark": "./assets/appstore-icon-dark.png"
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.rmehra831.oneDriveVensarApp"
    },
    "android": {
      "icon": "./assets/android-icons/mipmap-xxxhdpi/ic_launcher.png",
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.rmehra831.oneDriveVensarApp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Use Face ID to securely unlock Vensar Drive and access your company files."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to securely unlock Vensar Drive and access your company files."
        }
      ],
      "expo-web-browser",
      "expo-image",
      "expo-font",
      [
        "expo-alternate-app-icons",
        [
          {
            "name": "Dark",
            "ios": "./assets/appstore-icon-dark.png",
            "android": {
              "foregroundImage": "./assets/playstore-icon-dark-foreground.png",
              "backgroundColor": "#000000"
            }
          }
        ]
      ]
    ]
  }
}
